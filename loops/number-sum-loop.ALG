algoritmo "SomadorNumerico (repetiçăo 3)"
var
   C, valor, S: Inteiro
inicio
      Para C <- 1 Ate 5 passo 1 faca
               Escreval("Digite um valor:")
               Leia(valor)
               S <- valor + S
      FimPara
      Escreval("A soma dos valores digitados é: ", S)
fimalgoritmo
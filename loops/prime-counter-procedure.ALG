algoritmo "ContadorDeNumerosPrimosProcedimento"
var
   C, N, ContDiv: Inteiro
Procedimento Primo(X, Y: Inteiro)
var
      Cont: Inteiro
Inicio
      Cont <- 0
      Repita
            Se (X % Y = 0) entao
               Cont <- Cont + 1
            FimSe
            Y <- Y + 1
      Ate(Y > X)
      Se (Cont = 2) entao
         Escreval("O n·mero ", X, " Ú primo.")
      Senao
           Escreval("O n·mero ", X, " nÒo Ú primo.")
      FimSe
FimProcedimento
inicio
      C <- 1
      Escreva("Digite um n·mero: ")
      Leia(N)
      Primo(N, C)
fimalgoritmo